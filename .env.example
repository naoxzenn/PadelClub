########################################
# APP
########################################
APP_NAME=PadelClub
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/PadelClub

########################################
# DATABASE
########################################
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=root
DB_PASSWORD=

########################################
# SESSION
########################################
SESSION_NAME=padelclub_session
SESSION_LIFETIME=120

########################################
# GOOGLE OAUTH
########################################
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/PadelClub/auth/google-callback.php

########################################
# SMTP MAIL CONFIGURATION
########################################
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=info@padelclub.com
SMTP_FROM_NAME="PadelClub Premium"

